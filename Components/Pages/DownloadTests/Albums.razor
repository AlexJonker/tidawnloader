@page "/download/album"
@using Tidawnloader.Services
@using Tidawnloader.Models
@inject Request Request

<PageTitle>Album Metadata</PageTitle>

<div class="min-h-screen flex items-center justify-center px-4">

    <div class="w-full max-w-xl space-y-8">
        <div class="space-y-4">

            @if (Album is null)
            {
                <div class="space-y-4">
                    <label class="text-sm text-gray-400">Album ID</label>

                    <div class="flex gap-2">
                        <input
                            class="flex-1 bg-neutral-950 border border-neutral-800 px-3 py-2 text-sm text-gray-200 focus:outline-none focus:ring-2 focus:ring-neutral-700 disabled:opacity-50"
                            @bind="albumId"
                            @bind:event="oninput"
                            @onkeydown="OnKeyDown"
                            type="text"
                            placeholder="1234567"
                            disabled="@IsLoading"
                        />

                        <button
                            class="px-5 py-2 bg-gray-200 text-black font-semibold hover:bg-white transition-colors duration-75 disabled:opacity-50 disabled:cursor-not-allowed"
                            @onclick="GetMetadata"
                            disabled="@(IsLoading || string.IsNullOrWhiteSpace(albumId))"
                        >
                            @(IsLoading ? "…" : "Get")
                        </button>
                    </div>
                </div>
            }
            else
            {
                <div class="flex gap-4">
                    @if (!string.IsNullOrEmpty(Album.Cover))
                    {
                        <img
                            src="@($"https://resources.tidal.com/images/{Album.Cover.Replace("-", "/")}/1280x1280.jpg")"
                            alt="Cover"
                            class="w-24 h-24 object-cover"
                        />
                    }

                    <div class="flex-1 space-y-1 min-w-0">
                        <h2 class="text-2xl font-semibold text-gray-200 truncate">@Album.Title</h2>
                        <p class="text-sm text-gray-400 truncate">@Album.Artist?.Name</p>
                        <p class="text-sm text-gray-400 truncate">@Album.Url</p>
                        <p class="text-sm text-gray-400 truncate">@Album.ReleaseDate</p>
                        <p class="text-sm text-gray-400 truncate">@Album.NumberOfTracks</p>
                        <p class="text-sm text-gray-400 truncate">@Album.Duration</p>
                        @foreach (var item in Album.AllTracks)
                        {
                            <p class="text-sm text-gray-400 truncate">@item.Title (@item.Id)</p>
                        }
                    </div>
                </div>
            }
        </div>
    </div>
</div>

@code {
    private string albumId { get; set; } = string.Empty;
    private Album? Album { get; set; }
    private bool IsLoading { get; set; }

    private async Task OnKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !IsLoading && !string.IsNullOrWhiteSpace(albumId))
            await GetMetadata();
    }

    private async Task GetMetadata()
    {
        if (IsLoading) return;

        IsLoading = true;

        Album = await Request.Make<Album>($"album?id={Uri.EscapeDataString(albumId.Trim())}");

        IsLoading = false;
    }

    private void Reset()
    {
        albumId = string.Empty;
        Album = null;
    }
}