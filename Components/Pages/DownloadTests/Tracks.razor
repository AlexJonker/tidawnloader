@page "/download/track"
@using Tidawnloader.Services
@using Tidawnloader.Models
@inject Downloader Downloader
@inject Request Request

<PageTitle>Download Track</PageTitle>

<div class="min-h-screen flex items-center justify-center px-4">

    <div class="w-full max-w-xl space-y-8">
        <div class="space-y-4">

            @if (Track is null)
            {
                <div class="space-y-4">
                    <label class="text-sm text-gray-400">Track ID</label>

                    <div class="flex gap-2">
                        <input
                            class="flex-1 bg-neutral-950 border border-neutral-800 px-3 py-2 text-sm text-gray-200 focus:outline-none focus:ring-2 focus:ring-neutral-700 disabled:opacity-50"
                            @bind="trackId"
                            @bind:event="oninput"
                            @onkeydown="OnKeyDown"
                            type="text"
                            placeholder="1234567"
                            disabled="@IsLoading"
                        />

                        <button
                            class="px-5 py-2 bg-gray-200 text-black font-semibold hover:bg-white transition-colors duration-75 disabled:opacity-50 disabled:cursor-not-allowed"
                            @onclick="GetMetadata"
                            disabled="@(IsLoading || string.IsNullOrWhiteSpace(trackId))"
                        >
                            @(IsLoading ? "…" : "Get")
                        </button>
                    </div>
                </div>
            }
            else
            {
                <div class="flex gap-4">
                    @if (!string.IsNullOrEmpty(Track.Album?.Cover))
                    {
                        <img
                            src="@($"https://resources.tidal.com/images/{Track.Album.Cover.Replace("-", "/")}/1280x1280.jpg")"
                            alt="Cover"
                            class="w-24 h-24 object-cover"
                        />
                    }

                    <div class="flex-1 space-y-1 min-w-0">
                        <h2 class="text-2xl font-semibold text-gray-200 truncate">@Track.Title</h2>
                        <p class="text-sm text-gray-400 truncate">@Track.Artist?.Name</p>
                        <p class="text-sm text-gray-400 truncate">@Track.Album?.Title</p>
                    </div>
                </div>

                <div class="flex gap-2 pt-2">
                    <button
                        class="flex-1 px-5 py-2 bg-gray-200 text-black font-semibold hover:bg-white transition-colors duration-75 disabled:opacity-50 disabled:cursor-not-allowed cursor-pointer"
                        @onclick="StartDownload"
                        disabled="@IsRunning"
                    >
                        @(IsRunning ? "..." : "Download")
                    </button>
                </div>
            }

            @if (State.Status != DownloadStatus.Idle)
            {
                <div class="pt-4 space-y-3 border-t border-neutral-800">

                    <p class="text-sm text-gray-400">
                        @StatusLabel
                    </p>

                    @if (State.Status == DownloadStatus.Downloading)
                    {
                        <div class="space-y-2">

                            <div class="h-2 bg-neutral-800 rounded-full overflow-hidden">
                                <div
                                    class="h-full bg-gray-200 transition-all duration-200"
                                    style="width: @($"{State.ProgressPercent:F0}%")">
                                </div>
                            </div>

                            <p class="text-xs text-gray-400">
                                @State.Message
                            </p>

                        </div>
                    }
                    else if (!string.IsNullOrEmpty(State.Message))
                    {
                        <p class="text-sm text-gray-200">
                            @State.Message
                        </p>
                    }

                    @if (!string.IsNullOrEmpty(State.Error))
                    {
                        <p class="text-sm text-red-400">
                            @State.Error
                        </p>
                    }

                    @if (State.Status == DownloadStatus.Done)
                    {

                        <p class="text-gray-400 truncate">
                            @State.FilePath
                        </p>

                        <button
                            class="w-full px-5 py-2 border border-neutral-700 text-gray-300 font-semibold hover:border-gray-400 hover:text-white transition-colors duration-75 cursor-pointer"
                            @onclick="Reset">
                            Close
                        </button>
                    }
                </div>
            }
        </div>
    </div>
</div>

@code {
    private string trackId { get; set; } = string.Empty;
    private DownloadState State { get; set; } = new();
    private Track? Track { get; set; }
    private bool IsLoading { get; set; }

    private bool IsRunning => State.Status is
        DownloadStatus.Resolving or
        DownloadStatus.GettingStream or
        DownloadStatus.Downloading;

    private string StatusLabel => State.Status switch
    {
        DownloadStatus.Resolving     => "Resolving",
        DownloadStatus.GettingStream => "Getting stream",
        DownloadStatus.Downloading   => "Downloading",
        DownloadStatus.Done          => "Done",
        DownloadStatus.Failed        => "Failed",
        _                            => "Starting"
    };

    private async Task OnKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !IsLoading && !string.IsNullOrWhiteSpace(trackId))
            await GetMetadata();
    }

    private async Task GetMetadata()
    {
        if (IsLoading) return;

        IsLoading = true;

        Track = await Request.Make<Track>($"info?id={Uri.EscapeDataString(trackId.Trim())}");

        IsLoading = false;
    }

    private async Task StartDownload()
    {
        if (IsRunning) return;

        var progress = new Progress<DownloadState>(state =>
        {
            State = state;
            InvokeAsync(StateHasChanged);
        });

        await Downloader.DownloadAsync(trackId.Trim(), progress);
    }

    private void Reset()
    {
        State = new DownloadState();
        trackId = string.Empty;
        Track = null;
    }
}